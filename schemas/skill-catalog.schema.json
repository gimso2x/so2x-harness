{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "so2x-harness skill catalog",
  "type": "object",
  "minProperties": 1,
  "additionalProperties": {
    "type": "object",
    "required": ["tier", "applies_to", "platforms", "priority", "rationale"],
    "properties": {
      "tier": {
        "type": "string",
        "enum": ["core", "recommended", "optional"]
      },
      "applies_to": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string"
        }
      },
      "platforms": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "enum": ["claude", "codex"]
        },
        "uniqueItems": true
      },
      "priority": {
        "type": "integer",
        "minimum": 0
      },
      "rationale": {
        "type": "string",
        "minLength": 1
      },
      "signals_any": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "workflow_tags": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "additionalProperties": false
  }
}
