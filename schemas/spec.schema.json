{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "so2x-harness thin spec",
  "description": "Lite spec.json schema for the thin personal per-project harness.",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "tasks"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "goal", "created_at", "updated_at"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "goal": {"type": "string", "minLength": 1},
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"}
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "role",
          "action",
          "status",
          "summary",
          "last_error",
          "depends_on",
          "artifacts",
          "updated_at"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^T[0-9]+$"},
          "role": {"type": "string", "enum": ["planning", "review", "dev"]},
          "action": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["pending", "in_progress", "blocked", "error", "done"]},
          "summary": {"type": "string"},
          "last_error": {"type": "string"},
          "depends_on": {
            "type": "array",
            "items": {"type": "string", "pattern": "^T[0-9]+$"}
          },
          "artifacts": {
            "type": "array",
            "items": {"type": "string"}
          },
          "updated_at": {"type": "string", "format": "date-time"}
        }
      }
    }
  }
}
