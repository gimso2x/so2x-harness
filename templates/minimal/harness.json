{
  "version": "0.1.0",
  "rule_file": "CLAUDE.md",
  "spec_file": "spec.json",
  "runners": {
    "planning": ["ccs", "run", "gpt54-plan"],
    "review": ["ccs", "run", "gpt54-review"],
    "dev": ["ccs", "run", "glm-dev"]
  },
  "timeout_sec": {
    "default": 600,
    "planning": 300,
    "review": 300,
    "dev": 900
  },
  "max_retries": {
    "planning": 1,
    "review": 1,
    "dev": 3
  },
  "prompt": {
    "include_rule_file": true,
    "include_completed_summaries": true,
    "include_last_error": true
  }
}
